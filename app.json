{
  "expo": {
    "name": "Recall",
    "slug": "recall",
    "scheme": "recall",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#5B8CFF"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.shoas.recall",
      "buildNumber": "1",
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "プロフィール写真を選択するために写真へのアクセスが必要です。",
        "NSCameraUsageDescription": "プロフィール写真を撮影するためにカメラへのアクセスが必要です。",
        "NSUserNotificationsUsageDescription": "次に会う日や予定の前日にリマインダーを送るために通知を使用します。",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#5B8CFF"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_EXTERNAL_STORAGE"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "@react-native-community/datetimepicker",
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#5B8CFF",
          "sounds": []
        }
      ]
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "b8f37e38-cd06-4d24-8deb-d34c81475269"
      }
    }
  }
}
